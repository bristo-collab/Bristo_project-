.promo-banners {
    padding: 60px 0;
    background: #fff;
}

.promo-banner-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
}

.promo-card {
    height: 450px;
    border-radius: 30px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    padding: 60px;
    overflow: hidden;
    position: relative;
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
}

.promo-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.1);
    transition: background 0.5s ease;
}

.promo-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
}

.promo-card:hover::after {
    background: rgba(0, 0, 0, 0);
}

.promo-content {
    max-width: 400px;
    position: relative;
    z-index: 2;
}

.promo-tag {
    display: inline-block;
    background: var(--primary-blue);
    color: white;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 20px;
    letter-spacing: 1.5px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
}

.promo-card h2 {
    font-size: 3.5rem;
    color: white;
    line-height: 1;
    margin-bottom: 15px;
    font-weight: 800;
    letter-spacing: -2px;
}

.promo-card .highlight {
    color: #fff;
    opacity: 0.9;
    text-decoration: underline;
    text-decoration-color: var(--primary-blue);
    text-underline-offset: 8px;
}

.promo-card p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.1rem;
    margin-bottom: 30px;
    font-weight: 300;
}

.btn-glass {
    padding: 14px 36px;
    font-size: 1rem;
    font-weight: 700;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s ease;
    background: rgba(255, 255, 255, 0.15);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    text-transform: uppercase;
    letter-spacing: 1px;
}

.btn-glass:hover {
    background: white;
    color: var(--text-dark);
    transform: scale(1.05);
}

@media (max-width: 1024px) {
    .promo-banner-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 600px) {
    .promo-card {
        padding: 40px 30px;
        height: 400px;
    }

    .promo-card h2 {
        font-size: 2.5rem;
    }
}
/* Banner with Product Image */
.promo-card-with-image {
    background: linear-gradient(135deg, #2d3748 0%, #4a5568 50%, #718096 100%);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 60px;
    position: relative;
    overflow: hidden;
}

.promo-card-with-image::after {
    display: none;
}

.promo-card-with-image .promo-content {
    flex: 0 0 50%;
    max-width: 450px;
    z-index: 2;
}

.promo-image {
    flex: 0 0 45%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    margin-right: 20px;
}

.promo-image img {
    max-width: 100%;
    max-height: 350px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.3));
    transition: transform 0.5s ease;
}

.promo-card-with-image:hover .promo-image img {
    transform: scale(1.05);
}

@media (max-width: 1024px) {
    .promo-card-with-image {
        flex-direction: column;
        text-align: center;
        padding: 50px 40px;
    }

    .promo-card-with-image .promo-content {
        flex: 1;
        max-width: 100%;
        margin-bottom: 30px;
    }

    .promo-image {
        flex: 1;
        margin-right: 0;
        max-height: 200px;
    }

    .promo-image img {
        max-height: 200px;
    }
}

@media (max-width: 600px) {
    .promo-card-with-image {
        padding: 40px 30px;
        height: auto;
        min-height: 400px;
    }

    .promo-image {
        max-height: 150px;
    }

    .promo-image img {
        max-height: 150px;
    }
}
